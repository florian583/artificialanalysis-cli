{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/florian583/artificialanalysis-cli/blob/main/schema/llm-output.schema.json",
  "title": "artificialanalysis-cli machine output",
  "type": "object",
  "required": ["schemaVersion", "ok", "command"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "ok": { "type": "boolean" },
    "command": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "meta": { "type": "object" },
    "data": {},
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "ok": { "const": true } } },
      "then": { "required": ["generatedAt", "sources", "meta", "data"] }
    },
    {
      "if": { "properties": { "ok": { "const": false } } },
      "then": { "required": ["error"] }
    }
  ],
  "additionalProperties": false
}
